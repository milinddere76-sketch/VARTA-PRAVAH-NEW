# VartaPravah Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://root:password@postgres:5432/temporal

# Temporal
TEMPORAL_ADDRESS=temporal:7233

# API Keys
GROQ_API_KEY=your_groq_api_key_here
WORLD_NEWS_API_KEY=your_world_news_api_key_here
SYNCLABS_API_KEY=your_synclabs_api_key_here

# YouTube Streaming (set per channel in app, or default here)
YOUTUBE_STREAM_KEY=your_youtube_stream_key_here
BACKEND_WORKER_HOST=backend-worker
BACKEND_WORKER_PORT=8001